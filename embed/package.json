{
  "name": "ziscus",
  "version": "0.1.0",
  "description": "Zero-JavaScript anonymous comment system — embeddable HTML/CSS generators for static sites",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ziscus": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "comments",
    "zero-javascript",
    "anonymous",
    "static-site",
    "moderation",
    "anti-spam"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HectorZarate/ziscus",
    "directory": "embed"
  },
  "homepage": "https://ziscus.com",
  "bugs": "https://github.com/HectorZarate/ziscus/issues",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsdown": "^0.12.0",
    "typescript": "^5.9.0",
    "vitest": "~3.0.9"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
