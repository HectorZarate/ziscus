{
  "name": "ziscus",
  "version": "0.1.0",
  "description": "Zero-JavaScript anonymous comment system — embeddable HTML/CSS generators for static sites",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist"],
  "keywords": ["comments", "zero-javascript", "anonymous", "static-site", "moderation", "anti-spam"],
  "license": "MIT",
  "devDependencies": {
    "tsdown": "^0.12.0",
    "typescript": "^5.9.0",
    "vitest": "~3.0.9"
  }
}
